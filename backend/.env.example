# AI Personal Cloud Drive - Environment Configuration
# Copy this file to .env and fill in your values.

# ---- Server ----
# Listen on all IPv6+IPv4 interfaces (required for public access)
CLOUD_DRIVE_HOST=::
CLOUD_DRIVE_PORT=8000

# ---- Auth ----
# IMPORTANT: Change this to a long random string!
CLOUD_DRIVE_JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# Default admin credentials (change after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---- DDNS (Cloudflare) ----
# Domain name that points to this server
DDNS_DOMAIN=files.balabalashowtime.icu
# How often to check if local IPv6 changed (seconds)
DDNS_CHECK_INTERVAL=60
# DNS TTL in seconds
DDNS_TTL=600

# Cloudflare API credentials
# API Token: https://dash.cloudflare.com/profile/api-tokens
#   → Create Token → Edit zone DNS (use the template)
# Zone ID:   found on your domain's overview page (right sidebar)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id
