# AI Personal Cloud Drive - Environment Configuration
# Copy this file to .env and fill in your values.

# ---- Server ----
# Listen on all IPv4 interfaces (use 0.0.0.0, not :: on Windows)
CLOUD_DRIVE_HOST=0.0.0.0
CLOUD_DRIVE_PORT=8000

# ---- Auth ----
# IMPORTANT: Change this to a long random string!
CLOUD_DRIVE_JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# Default admin credentials (change after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---- Domain (for display / health check) ----
DDNS_DOMAIN=your-domain.example.com

# ---- Cloudflare API (optional, only for DDNS legacy) ----
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
